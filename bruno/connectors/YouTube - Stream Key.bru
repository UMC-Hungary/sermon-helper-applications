meta {
  name: YouTube - Stream Key
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/connectors/youtube/stream-key
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("response has rtmpUrl", function() {
    expect(res.body).to.have.property('rtmpUrl');
  });
}
